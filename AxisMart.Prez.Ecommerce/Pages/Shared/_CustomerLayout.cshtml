<!DOCTYPE html>
<html lang="fa" dir="rtl" x-data="{ darkMode: localStorage.getItem('customerDarkMode') === 'true' }" x-init="$watch('darkMode', val => localStorage.setItem('customerDarkMode', val))" :class="darkMode ? 'dark' : ''">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل کاربری اکسیس‌مارت</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Vazirmatn', sans-serif;
        }

        .sidebar-item {
            transition: all 0.2s ease;
        }

            .sidebar-item:hover {
                background-color: #eef2ff;
                padding-right: 1.25rem;
            }

        .dark .sidebar-item:hover {
            background-color: #374151;
        }

        .card-hover {
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .card-hover:hover {
                transform: translateY(-4px);
                box-shadow: 0 20px 25px -12px rgba(0,0,0,0.1);
            }

        .dark body {
            background-color: #111827;
            color: #e5e7eb;
        }

        .dark .bg-white {
            background-color: #1f2937;
        }

        .dark .bg-gray-50 {
            background-color: #111827;
        }

        .dark .border-gray-200 {
            border-color: #374151;
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900">

    <div class="flex h-screen overflow-hidden">
        <!-- Customer Sidebar -->
        <aside class="w-72 bg-white dark:bg-gray-800 shadow-xl overflow-y-auto z-10 flex-shrink-0 border-l dark:border-gray-700">
            <div class="p-5 border-b dark:border-gray-700 flex items-center gap-3">
                <div class="w-10 h-10 bg-indigo-100 dark:bg-indigo-900 rounded-full flex items-center justify-center text-indigo-700 dark:text-indigo-300 font-bold">ش</div>
                <div><p class="font-bold">شهرام حسینی</p><p class="text-xs text-gray-500 dark:text-gray-400">مشتری طلایی</p></div>
            </div>
            <nav class="p-3 space-y-1">
                <a href="/Customer" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg @(Context.Request.Path == "/Customer" ? "bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300" : "text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700")">
                    <i class="fas fa-tachometer-alt w-5"></i> پیشخوان
                </a>
                <a href="/Customer/Orders" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-shopping-bag w-5"></i> سفارشات من
                </a>
                <a href="/Customer/Wishlist" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-heart w-5"></i> علاقه‌مندی‌ها
                </a>
                <a href="/Customer/Profile" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-address-card w-5"></i> اطلاعات شخصی
                </a>
                <a href="/Customer/Addresses" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-map-marker-alt w-5"></i> آدرس‌ها
                </a>
                <hr class="my-3 dark:border-gray-700">
                <a href="/my-account/Logout" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20">
                    @Html.AntiForgeryToken()
                    <i class="fas fa-sign-out-alt w-5"></i> خروج
                </a>
            </nav>
        </aside>

        <!-- Main Customer Area -->
        <div class="flex-1 overflow-y-auto">
            <header class="bg-white dark:bg-gray-800 sticky top-0 shadow-sm px-6 py-4 flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <button id="mobileSidebarToggle" class="md:hidden text-gray-500"><i class="fas fa-bars text-xl"></i></button>
                    <h1 class="font-bold text-lg">@ViewData["Title"]</h1>
                </div>
                <div class="flex gap-4">
                    <button click ="darkMode = !darkMode" class="text-gray-500 text-xl hover:text-indigo-600">
                        <i :class="darkMode ? 'fa-sun' : 'fa-moon'"></i>
                    </button>
                    <i class="fas fa-bell text-gray-500 text-xl hover:text-indigo-600 cursor-pointer"></i>
                    <a href="/Cart" class="text-gray-500 hover:text-indigo-600 relative">
                        <i class="fas fa-shopping-cart text-xl"></i>
                        <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">۳</span>
                    </a>
                </div>
            </header>
            <main class="p-6">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        const sidebar = document.querySelector('aside');
        const toggleBtn = document.getElementById('mobileSidebarToggle');
        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => sidebar.classList.toggle('-translate-x-full'));
        }
        // On window resize >768, remove transform if present
        window.addEventListener('resize', () => {
            if (window.innerWidth >= 768) sidebar.classList.remove('-translate-x-full');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>