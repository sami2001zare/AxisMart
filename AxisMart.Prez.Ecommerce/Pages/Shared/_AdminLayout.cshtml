@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    var isAdmin = (await AuthorizationService.AuthorizeAsync(User, "AdminOnly")).Succeeded;
    // bool isAdmin = User.Identity.IsAuthenticated && User.IsInRole("Manager");
    if (!isAdmin && !Context.Request.Path.StartsWithSegments("/management/Login"))
    {
        Context.Response.Redirect("/management/Login");
        IgnoreBody(); // <-- THIS PREVENTS THE ERROR
        return;
    }
}


<!DOCTYPE html>
<html lang="fa" dir="rtl" x-data="{ darkMode: localStorage.getItem('adminDarkMode') === 'true' }" x-init="$watch('darkMode', val => localStorage.setItem('adminDarkMode', val))" :class="darkMode ? 'dark' : ''">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل مدیریت اکسیس‌مارت</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Vazirmatn', sans-serif;
        }

        .sidebar-item {
            transition: all 0.2s ease;
        }

        .sidebar-item:hover {
            background-color: #eef2ff;
            padding-right: 1.25rem;
        }

        .dark .sidebar-item:hover {
            background-color: #374151;
        }

        .card-hover {
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card-hover:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 25px -12px rgba(0,0,0,0.1);
        }

        .dark body {
            background-color: #111827;
            color: #e5e7eb;
        }

        .dark .bg-white {
            background-color: #1f2937;
        }

        .dark .bg-gray-50 {
            background-color: #111827;
        }

        .dark .border-gray-200 {
            border-color: #374151;
        }

        .dark .text-gray-600 {
            color: #9ca3af;
        }
    </style>
</head>
<body class="bg-gray-100 dark:bg-gray-900">

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside class="w-72 bg-white dark:bg-gray-800 shadow-xl overflow-y-auto z-10 flex-shrink-0">
            <div class="p-5 border-b dark:border-gray-700">
                <div class="text-2xl font-bold text-indigo-600 dark:text-indigo-400 text-center">اکسیس‌مارت</div>
                <div class="text-xs text-gray-400 text-center mt-1">پنل مدیریت</div>
            </div>
            <nav class="p-3 space-y-1">
                <a href="/Admin" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 @(Context.Request.Path == "/Admin" ? "bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300" : "hover:bg-gray-100 dark:hover:bg-gray-700")">
                    <i class="fas fa-tachometer-alt w-5"></i> داشبورد
                </a>
                <a href="/Admin/Products" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-box w-5"></i> محصولات
                </a>
                <a href="/Admin/Orders" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-shopping-cart w-5"></i> سفارشات
                </a>
                <a href="/Admin/Users" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-users w-5"></i> کاربران
                </a>
                <a href="/Admin/Categories" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-tags w-5"></i> دسته‌بندی
                </a>
                <a href="/Admin/Settings" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-cog w-5"></i> تنظیمات
                </a>
                <hr class="my-3 dark:border-gray-700">
                <a href="/Account/Logout" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-lg text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20">
                    <i class="fas fa-sign-out-alt w-5"></i> خروج
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-y-auto">
            <!-- Top Bar -->
            <header class="bg-white dark:bg-gray-800 shadow-sm px-6 py-4 flex justify-between items-center sticky top-0 z-20">
                <div class="flex items-center gap-4">
                    <button id="sidebarToggle" class="text-gray-500 hover:text-indigo-600 dark:text-gray-400"><i class="fas fa-bars text-xl"></i></button>
                    <div class="relative">
                        <i class="fas fa-search absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input type="text" placeholder="جستجو در مدیریت..." class="pr-10 pl-4 py-2 border dark:border-gray-600 dark:bg-gray-700 rounded-xl w-64 focus:outline-none focus:ring-2 focus:ring-indigo-300">
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <i class="fas fa-bell text-gray-500 text-xl hover:text-indigo-600 cursor-pointer"></i>
                    <button click ="darkMode = !darkMode" class="text-gray-500 text-xl hover:text-indigo-600">
                        <i :class="darkMode ? 'fa-sun' : 'fa-moon'"></i>
                    </button>
                    <div class="flex items-center gap-2 cursor-pointer">
                        <div class="w-8 h-8 bg-indigo-100 dark:bg-indigo-900 rounded-full flex items-center justify-center text-indigo-700 dark:text-indigo-300 font-bold">مد</div>
                        <span class="font-medium hidden md:inline">مدیر سیستم</span>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <main class="p-6">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        // Sidebar toggle for mobile
        const sidebar = document.querySelector('aside');
        const toggleBtn = document.getElementById('sidebarToggle');
        if (toggleBtn && window.innerWidth < 768) {
            sidebar.classList.add('-translate-x-full');
            toggleBtn.addEventListener('click', () => sidebar.classList.toggle('-translate-x-full'));
        } else if (toggleBtn) {
            toggleBtn.addEventListener('click', () => sidebar.classList.toggle('w-20'));
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>