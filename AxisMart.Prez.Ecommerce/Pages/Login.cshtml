@page
@model AxisMart.Prez.Ecommerce.Pages.LoginModel
@{
    ViewData["Title"] = "ورود به حساب";
}
<div class="container mx-auto max-w-md mt-20 p-6 bg-white rounded-2xl shadow">
    <h2 class="text-2xl font-bold text-center mb-6">ورود به اکسیس‌مارت</h2>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>
        <div class="mb-4">
            <label class="block mb-1">شماره موبایل</label>
            <input asp-for="LoginVm.Phone" class="w-full border rounded-lg px-4 py-2" dir="ltr" />
            <span asp-validation-for="LoginVm.Phone" class="text-red-500 text-sm"></span>
        </div>
        <div class="mb-4">
            <label class="block mb-1">رمز عبور</label>
            <input asp-for="LoginVm.Password" class="w-full border rounded-lg px-4 py-2" dir="ltr" />
            <span asp-validation-for="LoginVm.Password" class="text-red-500 text-sm"></span>
        </div>
        <button type="submit" class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 transition">
            دریافت کد تایید
        </button>
    </form>
  @*   @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="mt-4 p-2 bg-green-100 text-green-700 rounded">@Model.Message</div>
    } *@
</div>
